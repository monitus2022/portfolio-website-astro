---
import PageLayout from "@/layouts/Base.astro";
import { Icon } from "astro-icon/components";
import journeyData from "../content/journey.json";

const fontSize = "text-base";

const meta = {
	description: "My Personal Info",
	title: "About",
};

const myStory = "My journey from auditing to software engineering wasn't planned—it was a pivot driven by my love for data's hidden stories, logic's elegant solutions, and applying tech to real-world problems."

---

<PageLayout meta={meta}>
	<h1 class="title mb-12">About Me</h1>
	<div class="prose prose-sm prose-cactus max-w-none">
		<!-- Introduction -->
		<section class="mb-8">
			<p class="leading-relaxed">
				{myStory}
			</p>
		</section>

		<!-- Life Journey -->
		<section class="mb-8">
			<h2 class="mb-6 text-2xl font-semibold">Life Journey</h2>
			<div class="space-y-8">
				{
					journeyData.map((phase) => (
						<div class="border-l-4 border-cactus pl-6">
							<h3 class="text-xl font-semibold text-cactus mb-2">{phase.phase}</h3>
							<div class="space-y-4 mb-4">
								{phase.milestones.map((milestone) => (
									<div class="flex items-center">
										<div class="flex w-20 flex-shrink-0 flex-col items-center pr-4">
											<Icon
												name="mdi:circle"
												class="text-cactus h-4 w-4"
											/>
											<span class={`text-cactus ${fontSize} font-semibold`}>{milestone.year}</span>
										</div>
										<div class="pl-4">
											<h4 class="text-lg font-medium">{milestone.title}</h4>
											<p class="text-sm text-gray-600 dark:text-gray-400">{milestone.subtitle}</p>
										</div>
									</div>
								))}
							</div>
							<p class={`mb-4 ${fontSize}`}>{phase.description}</p>
							{phase.skills && phase.skills.length > 0 && (
								<div class="mb-4">
									<h4 class="text-lg font-semibold mb-2">Skills Obtained</h4>
									<ul class={`list-disc list-inside ${fontSize} space-y-1`}>
										{phase.skills.map((skill) => <li>{skill}</li>)}
									</ul>
								</div>
							)}
							<div class="mb-4 text-center">
								<img src={phase.meme} alt="Meme" class="w-full max-w-sm h-auto rounded mx-auto" />
								<p class="text-sm text-gray-600 dark:text-gray-400 mt-2 italic">{phase.hint}</p>
							</div>
						</div>
					))
				}
			</div>
		</section>

		<!-- Optional: Interests or Call-to-Action -->
		<section>
			<h2 class="mb-4 text-2xl font-semibold">Hobbies</h2>
				<div class="flex flex-wrap gap-2">
						<span class="bg-cactus/10 text-cactus inline-flex items-center rounded-full px-3 py-1 text-sm font-medium">
							<Icon name="mdi:music-clef-treble" class="mr-2 h-6 w-6" />
							Music & Singing
						</span>
						<span class="bg-cactus/10 text-cactus inline-flex items-center rounded-full px-3 py-1 text-sm font-medium">
							<Icon name="fluent:calligraphy-pen-20-filled" class="mr-2 h-6 w-6" />
							Caligraphy
						</span>
						<span class="bg-cactus/10 text-cactus inline-flex items-center rounded-full px-3 py-1 text-sm font-medium">
							<Icon name="mdi:coffee" class="mr-2 h-6 w-6" />
							Coffee Brewing
						</span>
						<span class="bg-cactus/10 text-cactus inline-flex items-center rounded-full px-3 py-1 text-sm font-medium">
							<Icon name="simple-icons:steam" class="mr-2 h-6 w-6" />
							Gaming
						</span>
				</div>						
		</section>
	</div>
</PageLayout>
